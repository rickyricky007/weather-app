<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Weather App</title>
    <link rel="stylesheet" href="main.css">
</head>
<body>
    <h1>Today Weather</h1>
    <form action="/getdata" method="post">
        <input type ="text" name="city" placeholder="enter the city name"/>
        <button type="submit">Search</button>
    </form>
    <% if (typeof weather !== 'undefined') { %>
        <div class="weather-card">
            <h2><%= weather.name %></h2>
            <p><%= (weather.main.temp - 273.15).toFixed(1) %>°C</p>
            <p><%= weather.weather[0].description %></p>
            <p>Humidity: <%= weather.main.humidity %>%</p>
            <p>Wind: <%= weather.wind.speed %> m/s</p>
            <p>Temp_Max: <%= (weather.main.temp_max -273.15).toFixed(1) %>°C</p>
            <p>Temp_Min: <%= (weather.main.temp_min -273.15).toFixed(1) %>°C</p>
        </div>
    <% } %>
</body>
</html>
